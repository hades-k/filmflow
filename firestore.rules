rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions collection - users can only access their own sessions
    match /sessions/{sessionId} {
      // Allow read if the user is authenticated and owns the session
      allow read: if request.auth != null && 
                     request.auth.uid == resource.data.userId;
      
      // Allow write (update/delete) if the user is authenticated and owns the session
      allow write: if request.auth != null && 
                      request.auth.uid == resource.data.userId;
      
      // Allow create if the user is authenticated and the userId matches
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.userId;
    }
  }
}
